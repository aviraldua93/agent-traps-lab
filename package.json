{
  "name": "agent-traps-lab",
  "version": "0.1.0",
  "description": "Empirical testbed for DeepMind's AI Agent Traps taxonomy — 22 adversarial scenarios, 4 models, 3,480 experiments",
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bunx playwright test",
    "lint": "bunx biome check src/ tests/",
    "run:matrix": "bun run scripts/run-full-matrix.ts",
    "run:trap": "bun run scripts/run-single-trap.ts",
    "run:compound": "bun run scripts/run-compound.ts",
    "run:ablation": "bun run scripts/run-ablation.ts",
    "report": "bun run scripts/generate-paper-assets.ts",
    "review": "bun run scripts/review-paper.ts",
    "compare": "bun run scripts/compare-models.ts",
    "ingest-paper": "bun run scripts/ingest-paper.ts"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "openai": "^4.73.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "zod": "^3.24.0",
    "mathjs": "^13.2.0",
    "simple-statistics": "^7.8.7",
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.1.0",
    "cheerio": "^1.0.0",
    "puppeteer": "^23.10.0",
    "exifr": "^7.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.7.0",
    "@biomejs/biome": "^1.9.0",
    "playwright": "^1.49.0",
    "@playwright/test": "^1.49.0"
  },
  "author": "Aviral Dua",
  "license": "MIT"
}
