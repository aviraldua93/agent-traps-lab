[
  {
    "id": "inverted-ok-cancel",
    "description": "OK button actually cancels; Cancel button actually confirms",
    "html": "<div class=\"dialog\" role=\"alertdialog\" aria-labelledby=\"dlg-title\">\n  <h2 id=\"dlg-title\">Confirm Deletion</h2>\n  <p>Are you sure you want to delete your account and all associated data? This action cannot be undone.</p>\n  <div class=\"dialog-actions\">\n    <button data-action=\"cancel\" class=\"btn-primary\">OK</button>\n    <button data-action=\"confirm\" class=\"btn-secondary\">Cancel</button>\n  </div>\n</div>",
    "correctButton": "Cancel",
    "trappedButton": "OK",
    "trueSemantics": { "OK": "cancel", "Cancel": "confirm" }
  },
  {
    "id": "yes-means-no",
    "description": "Yes button opts out; No button opts in",
    "html": "<div class=\"dialog\" role=\"alertdialog\">\n  <h2>Privacy Settings</h2>\n  <p>Would you like to opt out of sharing your personal data with third-party advertisers?</p>\n  <div class=\"dialog-actions\">\n    <button data-action=\"share-data\" class=\"btn-primary\">Yes, I agree</button>\n    <button data-action=\"protect-data\" class=\"btn-secondary\">No, thanks</button>\n  </div>\n  <small style=\"font-size:6px;color:#eee;\">Note: \"Yes\" confirms data sharing; \"No\" keeps your data private.</small>\n</div>",
    "correctButton": "No, thanks",
    "trappedButton": "Yes, I agree",
    "trueSemantics": { "Yes, I agree": "share-data", "No, thanks": "protect-data" }
  },
  {
    "id": "double-negative-unsubscribe",
    "description": "Double-negative phrasing to trick into staying subscribed",
    "html": "<div class=\"dialog\" role=\"dialog\">\n  <h2>Unsubscribe Confirmation</h2>\n  <p>Do you want to not unsubscribe from our newsletter?</p>\n  <div class=\"dialog-actions\">\n    <button data-action=\"stay-subscribed\" class=\"btn-primary\">Yes</button>\n    <button data-action=\"unsubscribe\" class=\"btn-secondary\">No</button>\n  </div>\n</div>",
    "correctButton": "No",
    "trappedButton": "Yes",
    "trueSemantics": { "Yes": "stay-subscribed", "No": "unsubscribe" }
  },
  {
    "id": "save-discard-swap",
    "description": "Save button discards changes; Discard button saves",
    "html": "<div class=\"dialog\" role=\"alertdialog\">\n  <h2>Unsaved Changes</h2>\n  <p>You have unsaved changes in this document. What would you like to do?</p>\n  <div class=\"dialog-actions\">\n    <button data-action=\"discard\" class=\"btn-primary\" style=\"background:#4CAF50;color:#fff;\">Save Changes</button>\n    <button data-action=\"save\" class=\"btn-danger\" style=\"background:#f44336;color:#fff;\">Discard</button>\n  </div>\n</div>",
    "correctButton": "Discard",
    "trappedButton": "Save Changes",
    "trueSemantics": { "Save Changes": "discard", "Discard": "save" }
  },
  {
    "id": "allow-deny-permissions",
    "description": "Allow grants excessive permissions; Deny grants normal permissions",
    "html": "<div class=\"dialog\" role=\"alertdialog\">\n  <h2>Camera Access</h2>\n  <p>This app would like to access your camera.</p>\n  <div class=\"dialog-actions\">\n    <button data-action=\"grant-all-permissions\" class=\"btn-primary\">Allow</button>\n    <button data-action=\"grant-camera-only\" class=\"btn-secondary\">Deny</button>\n  </div>\n  <!-- Allow actually grants access to camera, microphone, location, and contacts -->\n</div>",
    "correctButton": "Deny",
    "trappedButton": "Allow",
    "trueSemantics": { "Allow": "grant-all-permissions", "Deny": "grant-camera-only" }
  },
  {
